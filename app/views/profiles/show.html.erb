<div class="container pt-3">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      <h1 class="float-left mb-5"><%= t('.title') %></h1>
      <table class="table">
        <tr>
          <th scope="row"><%= User.human_attribute_name(:email) %></th>
          <td><%= current_user.email %></td>
        </tr>
        <tr>
          <th scope="row"><%= User.human_attribute_name(:nickname) %></th>
          <td><%= current_user.nickname %></td>
        </tr>
        <tr>
          <th scope="row"><%= User.human_attribute_name(:avatar) %></th>
          <td><%= image_tag current_user.avatar.url, class: 'rounded-circle', size: '50x50' %></td>
        </tr>
      </table>
      <div class="d-flex justify-content-end">
        <%= link_to t('defaults.edit'), edit_profile_path, class: 'btn btn-success float-right' %>
      </div>
      <div class="user-stats">
        <h2>💜グミ投稿統計</h2>

        <div class="stat-item">
          <span class="stat-label">総合投稿数</span>
          <span class="stat-value"><%= @total_reviews_count %></span>件
        </div>

        <div class="stat-item">
          <span class="stat-label">今月の投稿数</span>
          <span class="stat-value"><%= @monthly_reviews_count %></span>件
        </div>

        <% if @monthly_reviews_count > 0 %>
          <div class="monthly-preferences mt-4">
            <h3 class="text-lg font-semibold mb-3">📊 今月の好みの傾向</h3>

            <style>
              .user-stats {
                margin-top: 2rem;
                padding: 1.5rem;
                background-color: #f8f9fa;
                border-radius: 8px;
              }

              .user-stats h2 {
                font-size: 1.5rem;
                font-weight: 600;
                margin-bottom: 1.5rem;
                color: #333;
              }

              .stat-item {
               margin-bottom: 1rem;
               font-size: 1.1rem;
              }

              .stat-label {
                font-weight: 500;
                color: #555;
              }

               .stat-value {
                font-weight: 700;
                color: #007bff;
                font-size: 1.3rem;
              }

               .monthly-preferences {
                margin-top: 2rem;
                padding: 1.5rem;
                background-color: #f9fafb;
                border-radius: 8px;
              }

               .monthly-preferences h3 {
                font-size: 1.125rem;
                font-weight: 600;
                margin-bottom: 1.5rem;
                color: #1f2937;
              }

               .preference-item {
                margin-bottom: 1.5rem;
              }

               .preference-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 0.5rem;
              }

               .preference-label {
                font-weight: 500;
                font-size: 0.875rem;
                color: #374151;
              }

              .progress-labels {
               display: flex;
               justify-content: space-between;
               width: 100%;
               margin-bottom: 0.5rem;
               font-size: 0.875rem;
               color: #6b7280;
              }

               .progress-label-left {
               font-weight: 500;
                text-align: left;
              }

               .progress-label-right {
                font-weight: 500;
                text-align: right;
              }

               .preference-value {
                font-size: 0.875rem;
                color: #6b7280;
                font-weight: 500;
              }

               .progress-bar-container {
                width: 100%;
                height: 12px;
                background-color: #e5e7eb;
                border-radius: 9999px;
                overflow: hidden;
                box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.1);
              }

               .progress-bar {
                height: 100%;
                border-radius: 9999px;
                transition: width 0.5s ease;
              }

              .progress-bar-blue {
               background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
              }

              .progress-bar-pink {
               background: linear-gradient(90deg, #ec4899 0%, #db2777 100%);
              }

              .progress-bar-yellow {
               background: linear-gradient(90deg, #fbbf24 0%, #f59e0b 100%);
              }

              .no-data-message {
               margin-top: 1rem;
               padding: 1rem;
               background-color: #fff3cd;
               border-radius: 4px;
               color: #856404;
               text-align: center;
              }
            </style>

            <!-- 硬さ -->
            <div class="preference-item mb-3">
              <div class="preference-header">
                <span class="preference-label">🩶 硬さ 🩶</span>
              </div>
              <div class="progress-labels">
                <span class="progress-label-left">とてもソフト</span>
                <span class="progress-label-right">とてもハード</span>
              </div>
              <div class="progress-bar-container">
                <div class="progress-bar progress-bar-blue" style="width: <%= (@monthly_avg_hardness / 5.0 * 100).round %>%"></div>
              </div>
            </div>
            <!-- 甘さ -->
            <div class="preference-item mb-3">
              <div class="preference-header">
                <span class="preference-label">🩷 甘さ 🩷</span>
              </div>
              <div class="progress-labels">
                <span class="progress-label-left">甘くない</span>
                <span class="progress-label-right">とても甘い</span>
              </div>
              <div class="progress-bar-container">
                <div class="progress-bar progress-bar-pink" style="width: <%= (@monthly_avg_sweetness / 5.0 * 100).round %>%"></div>
              </div>
            </div>

            <!-- 酸っぱさ -->
            <div class="preference-item">
              <div class="preference-header">
                <span class="preference-label">💛 酸っぱさ 💛</span>
              </div>
              <div class="progress-labels">
                <span class="progress-label-left">酸っぱくない</span>
                <span class="progress-label-right">とても酸っぱい</span>
              </div>
              <div class="progress-bar-container">
                <div class="progress-bar progress-bar-yellow" style="width: <%= (@monthly_avg_sourness / 5.0 * 100).round %>%"></div>
              </div>
            </div>
          </div>
        <% else %>
          <p class="no-data-message">今月の投稿がまだありません</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
