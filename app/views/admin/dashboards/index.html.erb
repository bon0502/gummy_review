<div class="container mt-4">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      <!-- ページタイトル -->
      <div class="mb-4">
        <h1>管理者ダッシュボード</h1>
        <p class="text-muted">ここは管理者専用のページです</p>
      </div>

      <!-- 統計情報カード -->
      <div class="row mb-4">
        <!-- ユーザー数カード -->
        <div class="col-md-6 mb-3">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">登録ユーザー数</h5>
              <p class="card-text display-4"><%= @users_count %></p>
              <%= link_to 'ユーザー一覧へ', admin_users_path, class: 'btn btn-primary' %>
            </div>
          </div>
        </div>

        <!-- 投稿数カード -->
        <div class="col-md-6 mb-3">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">投稿数</h5>
              <p class="card-text display-4"><%= @reviews_count %></p>
              <%= link_to '投稿一覧へ', admin_reviews_path, class: 'btn btn-primary' %>
            </div>
          </div>
        </div>
      </div>

      <!-- 最近の投稿一覧カード -->
      <div class="card">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">最近の投稿</h4>
        </div>
        <div class="card-body">
          <% if @recent_reviews.any? %>
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>グミ名</th>
                  <th>ユーザー</th>
                  <th>評価</th>
                  <th>投稿日時</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @recent_reviews.each do |review| %>
                  <tr>
                    <td><%= review.id %></td>
                    <td><%= review.gummy_name %></td>
                    <td><%= review.user.nickname %></td>
                    <td><%= review.rating %></td>
                    <td><%= l(review.created_at, format: :short) %></td>
                    <td>
                      <%= link_to '詳細', admin_review_path(review), class: 'btn btn-sm btn-info' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="text-muted">投稿がありません</p>
          <% end %>
        </div>
      </div>

      <!-- 管理機能へのリンク -->
      <div class="mt-4">
        <h4>管理機能</h4>
        <div class="list-group">
          <%= link_to 'ユーザー管理', admin_users_path, class: 'list-group-item list-group-item-action' %>
          <%= link_to '投稿管理', admin_reviews_path, class: 'list-group-item list-group-item-action' %>
        </div>
      </div>
    </div>
  </div>
</div>
