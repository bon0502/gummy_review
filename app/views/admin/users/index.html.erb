<% if notice %>
  <div class="alert alert-success">
    <%= notice %>
  </div>
<% end %>

<% if alert %>
  <div class="alert alert-danger">
    <%= alert %>
  </div>
<% end %>

<div class="container">
  <h1>ユーザー管理</h1>

  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>ニックネーム</th>
        <th>メール</th>
        <th>権限</th>
        <th>登録日</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.nickname %></td>
          <td><%= user.email %></td>
          <td><%= user.role_i18n %></td>
          <td><%= l user.created_at, format: :short %></td>
          <td>
            <%= link_to '編集', edit_admin_user_path(user), class: 'btn btn-sm btn-primary' %>
            <%= button_to '削除', admin_user_path(user), method: :delete, class: 'btn btn-danger btn-sm',
                form: { data: { turbo_confirm: '本当に削除しますか？' } } %>
            <%= button_to 'パスワードリセット', reset_password_admin_user_path(user),
                method: :patch,
                class: 'btn btn-warning btn-sm',
                form: { data: { turbo_confirm: 'パスワードをリセットしますか？' } } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= paginate @users %>
</div>
