<div class="container mt-4">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      <div class="card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
          <h2 class="mb-0">ユーザー詳細</h2>
          <%= link_to '一覧に戻る', admin_reviews_path, class: 'btn btn-sm btn-light' %>
        </div>

        <div class="card-body">
          <div class="mb-3">
            <strong>ニックネーム:</strong> <%= @user.nickname %>
          </div>

          <div class="mb-3">
            <strong>メール:</strong> <%= @user.email %>
          </div>

          <div class="mb-3">
            <strong>ロール:</strong>
            <span class="badge <%= @user.admin? ? 'bg-danger' : 'bg-secondary' %>">
              <%= @user.role %>
            </span>
          </div>

          <div class="mb-3">
            <strong>登録日時:</strong> <%= l(@user.created_at, format: :long) %>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header">
          <h4>投稿一覧</h4>
        </div>
        <div class="card-body">
          <% if @user.reviews.any? %>
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>グミ名</th>
                  <th>評価</th>
                  <th>投稿日時</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @user.reviews.each do |review| %>
                  <tr>
                    <td><%= review.id %></td>
                    <td><%= review.gummy_name %></td>
                    <td><%= review.rating %></td>
                    <td><%= l(review.created_at, format: :short) %></td>
                    <td>
                      <%= link_to '詳細', admin_review_path(review), class: 'btn btn-sm btn-info' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="text-muted">投稿がありません</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <!-- ページネーション -->
    < class="d-flex justify-content-center mt-4">
      <%= paginate @reviews %>
    </div>
  <% else %>
    <p class="text-muted">投稿がありません</p>
  <% end %>
  <!-- 管理画面に戻るボタン -->
  <div class="mt-4 text-center">
    <%= link_to '管理画面トップに戻る', admin_root_path, class: 'btn btn-secondary' %>
  </div>
</div>
