<tr id="comment-<%= comment.id %>">
  <td style="width: 60px">
    <% if comment.user.avatar? %>
      <%=image_tag comment.user.avatar.url, width: "50", height: "50", class: "rounded-circle" %>
    <% else %>
      <%= image_tag "3D907821-682B-4811-A279-7ADECE821E4B.png", width: "50", height: "50", class: "rounded-circle" %>
    <% end %>
  </td>
  <td>
    <h3 class="small"><%= comment.user.nickname %></h3>
    <p><%= simple_format(comment.body) %></p>
    <p class="text-muted small text-end"><%= comment.created_at.strftime("%Y年%m月%d日 %H:%M") %></p>
  </td>
  <% if current_user.own?(comment) %>
    <td class="action">
      <ul class="list-inline justify-content-center" style="float: right;">
        <li class="list-inline-item">
          <%= link_to review_comment_path(comment.review, comment), method: :delete, remote: true, class: "delete-comment-link btn-delete",
          data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } do %>
            <i class="bi bi-trash-fill"></i>
          <% end %>
        </li>
      </ul>
    </td>
  <% end %>
</tr>
