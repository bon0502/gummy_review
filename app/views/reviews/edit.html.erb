<h1 class="title">🌟レビュー編集🌟</h1>

<%= form_with model: @review, class: "review-form", enctype: "multipart/form-data", data: { controller: "image-resize" } do |f| %>

  <div class="form-group">
    <%= f.label :photo_url, "グミ画像（メイン１枚）" %>

    <!-- 既存のメイン画像を表示 -->
    <% if @review.photo_url.present? %>
      <div class="mb-2">
        <%= image_tag @review.photo_url.url, class: "img-thumbnail", style: "max-width: 200px;" %>
        <div class="form-check">
          <%= f.check_box :remove_photo_url, class: "form-check-input" %>
          <%= f.label :remove_photo_url, "この画像を削除", class: "form-check-label" %>
        </div>
      </div>
    <% end %>

    <!-- 新しい画像をアップロード -->
    <%= f.file_field :photo_url,
          data: {
              image_resize_target: "main",
              action: "change->image-resize#resizeMain"
          },
          accept: 'image/*' %>
  </div>

  <!-- サブ画像 -->
  <div class="form-group">
    <label>他のグミたち(複数選択可)</label>

    <!-- 既存のサブ画像を表示 -->
    <% if @review.main_images.any? %>
      <div class="mb-3">
        <p>現在のサブ画像:</p>
        <div class="row">
          <% @review.main_images.each do |main_image| %>
            <div class="col-md-3 mb-2">
              <%= image_tag main_image.image.url, class: "img-thumbnail" %>
              <%= f.fields_for :main_images, main_image do |img_f| %>
                <div class="form-check">
                  <%= img_f.check_box :_destroy, class: "form-check-input" %>
                  <%= img_f.label :_destroy, "削除", class: "form-check-label" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 新しいサブ画像をアップロード -->
    <input type="file"
           name="review[main_images_attributes][][image]"
           id="sub_images"
           class="form-control"
           multiple
           accept="image/*"
           data-image-resize-target="sub"
           data-action="change->image-resize#resizeSub">
  </div>

  <div class="form-group">
    <%= f.label :gummy_name, "グミの名前" %>
    <%= f.text_field :gummy_name %>
  </div>

  <div class="form-group">
    <label>総合評価</label>
    <%= f.select :rating, [["⭐️", 1], ["⭐⭐", 2], ["⭐⭐⭐", 3], ["⭐⭐⭐⭐", 4], ["⭐⭐⭐⭐⭐", 5]] %>
  </div>

  <!-- 横並び -->
  <div class="row-group">
    <div class="fw-bold">
      <%= f.label :flavor, "🩵フレーバー🩵" %>
      <%= f.text_field :flavor %>
    </div>

    <div class="fw-bold">
      <%= f.label :hardness, "🩶硬さ🩶" %>
      <%= f.select :hardness, [["とてもソフト", 1], ["ソフト", 2], ["普通", 3], ["ハード", 4], ["とてもハード", 5]] %>
    </div>

    <div class="fw-bold">
      <%= f.label :sweetness, "🩷甘さ🩷" %>
      <%= f.select :sweetness, [["甘くない", 1], ["甘さ控えめ", 2], ["甘い", 3], ["少し甘い", 4], ["とても甘い", 5]] %>
    </div>

    <div class="fw-bold">
      <%= f.label :sourness, "💛酸味💛" %>
      <%= f.select :sourness, [["酸っぱくない", 1], ["酸っぱさ控えめ", 2], ["酸っぱい", 3], ["少し酸っぱい", 4], ["とても酸っぱい", 5]] %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :manufacturer_name, "💚メーカー💚" %>
    <%= f.text_field :manufacturer_name %>
  </div>

  <div class="form-group">
    <%= f.label :comment, "⭐グミの特徴⭐" %>
    <%= f.text_area :comment %>
  </div>

  <div class="submit-area">
    <%= f.submit "投稿！" %>
  </div>

<% end %>
