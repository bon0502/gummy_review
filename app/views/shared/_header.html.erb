<header class="header">
  <div class="header-container">
    <!-- ロゴ -->
    <h1 class="header-logo">
      <%= link_to root_path do %>
        <%= image_tag '530F18F2-5BFD-4749-99FE-214D183EAD4B.png', class: 'header-logo-image'  %>
      <% end %>
    </h1>
    <!-- ナビゲーション -->
    <nav class="header-nav">
      <%= link_to "グミ一覧໒꒱", reviews_path %>
      <%= link_to "グミ投稿໒꒱", new_review_path %>
      <%= link_to "いいね一覧໒꒱", likes_path %>
      <%= link_to "ログアウト໒꒱", logout_path, data: { turbo_method: :delete } %>
      <%= link_to profile_path do %>
        <%= image_tag current_user.avatar.url, class: 'rounded-circle mr15', width: '40', height: '40' %>
      <% end %>
    </nav>
  </div>
</header>
